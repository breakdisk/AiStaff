DATABASE_URL=postgres://dev:devpassword@localhost:5432/aistaffapp
KAFKA_BROKERS=localhost:9092

# ── OAuth providers (create apps at the URLs below) ───────────────────────────
# GitHub:   github.com/settings/developers → New OAuth App
#           Callback: http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# Google:   console.cloud.google.com → Credentials → OAuth 2.0
#           Callback: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# LinkedIn: developer.linkedin.com → Create App → Auth tab
#           Callback: http://localhost:3000/api/auth/callback/linkedin
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret

# NextAuth (Auth.js v5) — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=replace_with_openssl_rand_base64_32
NEXTAUTH_URL=http://localhost:3000

# Identity service base URL (used by Next.js auth callbacks)
IDENTITY_SERVICE_URL=http://localhost:3001
MCP_FS_ROOT=/tmp/agent-workspace
ZK_VERIFYING_KEY_PATH=./config/liveness_vk.bin
RUST_LOG=info
SQLX_OFFLINE=true

# v2 — Managed Digital Workforce services
SMTP_HOST=smtp.mailgun.org
SMTP_FROM=noreply@aistaff.app
PLATFORM_DID=did:aistaff:platform

# Inter-service URLs (defaults work for local dev; override for Docker)
COMPLIANCE_SERVICE_URL=http://localhost:3006
MCP_SERVER_URL=http://localhost:4040
