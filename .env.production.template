# ── AiStaff Production Environment Variables ─────────────────────────────────
# Paste each value into Dokploy UI → service → Environment tab.
# NEVER commit a file containing real values.
# ──────────────────────────────────────────────────────────────────────────────

# ── Domain ────────────────────────────────────────────────────────────────────
APP_DOMAIN=aistaffglobal.com

# ── Auth.js (NextAuth v5) ──────────────────────────────────────────────────────
NEXTAUTH_URL=https://aistaffglobal.com
AUTH_URL=https://aistaffglobal.com
# openssl rand -base64 32
NEXTAUTH_SECRET=REPLACE_WITH_RANDOM_32_BYTE_BASE64

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=aistaff
# openssl rand -base64 24
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
POSTGRES_DB=aistaff

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BROKERS=kafka:9092

# ── JWT signing keys (RS256) ──────────────────────────────────────────────────
# openssl genrsa -out jwt_private.pem 2048
# openssl rsa -in jwt_private.pem -pubout -out jwt_public.pem
# base64 -w0 jwt_private.pem   → JWT_PRIVATE_KEY
# base64 -w0 jwt_public.pem    → JWT_PUBLIC_KEY
# rm jwt_private.pem jwt_public.pem
JWT_PRIVATE_KEY=REPLACE_WITH_BASE64_ENCODED_PEM
JWT_PUBLIC_KEY=REPLACE_WITH_BASE64_ENCODED_PEM

# ── OAuth providers ────────────────────────────────────────────────────────────
# GitHub callback: https://aistaffglobal.com/api/auth/callback/github
GITHUB_CLIENT_ID=REPLACE
GITHUB_CLIENT_SECRET=REPLACE

# Google callback: https://aistaffglobal.com/api/auth/callback/google
GOOGLE_CLIENT_ID=REPLACE
GOOGLE_CLIENT_SECRET=REPLACE

# LinkedIn callback: https://aistaffglobal.com/api/auth/callback/linkedin
LINKEDIN_CLIENT_ID=REPLACE
LINKEDIN_CLIENT_SECRET=REPLACE

# ── Anthropic ─────────────────────────────────────────────────────────────────
# Required for /api/pm-agent and /api/proposal-copilot (LangGraph routes)
# https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=REPLACE

# ── OpenAI (embeddings only) ───────────────────────────────────────────────────
# Required for quality-gate plagiarism detection (text-embedding-3-small)
# https://platform.openai.com → API Keys
# Leave blank to skip vector plagiarism checks (Claude text analysis still runs)
OPENAI_API_KEY=REPLACE

# ── AWS SES SMTP ──────────────────────────────────────────────────────────────
# 1. Verify domain aistaffglobal.com in SES console:
#    SES → Verified identities → Create identity → Domain → aistaffglobal.com
#    Add the DKIM CNAME records to your DNS.
#
# 2. Create SMTP credentials:
#    SES → SMTP settings → Create SMTP credentials
#    This creates an IAM user and generates SMTP-specific username + password.
#    (NOT the same as your AWS access key / secret key)
#
# 3. If your account is in SES sandbox, request production access:
#    SES → Account dashboard → Request production access
#    (Sandbox only sends to verified email addresses.)
#
# 4. Region: use the SES endpoint for your AWS region, e.g.:
#    us-east-1  → email-smtp.us-east-1.amazonaws.com
#    eu-west-1  → email-smtp.eu-west-1.amazonaws.com
#    ap-southeast-1 → email-smtp.ap-southeast-1.amazonaws.com
SMTP_HOST=email-smtp.us-east-1.amazonaws.com
SMTP_PORT=587
SMTP_FROM=noreply@aistaffglobal.com
# From SES → SMTP settings → Create SMTP credentials
SMTP_USERNAME=REPLACE_WITH_SES_SMTP_USERNAME
SMTP_PASSWORD=REPLACE_WITH_SES_SMTP_PASSWORD

# ── Notification service extras (optional — leave blank if not using) ──────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_WHATSAPP_NUMBER=
FCM_SERVER_KEY=
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# ── AES-256 key for encrypting OAuth integration tokens at rest ────────────────
# openssl rand -base64 32  (must be exactly 32 bytes base64-encoded)
INTEGRATION_TOKEN_ENCRYPTION_KEY=REPLACE_WITH_32_BYTE_BASE64

# ── Platform identity ──────────────────────────────────────────────────────────
PLATFORM_DID=did:web:aistaffglobal.com

# ── Wasm + ZKP (Phase 2 — leave as defaults) ──────────────────────────────────
WASM_PLUGIN_DIR=/plugins
MCP_FS_ROOT=/workspace
ZKP_VERIFIER_KEY=

# ── Logging ───────────────────────────────────────────────────────────────────
RUST_LOG=info,sqlx=warn
